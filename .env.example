PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# Database
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/water-tank?retryWrites=true&w=majority

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_ACCESS_EXPIRES=30d
JWT_REFRESH_EXPIRES=60d
TRUST_PROXY=false

# Upload limits
UPLOAD_MAX_FILE_SIZE=5242880

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_JSON='{ "type": "service_account", "project_id": "your-project", "private_key": "...", "client_email": "..." }'

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Error Tracking (Optional)
SENTRY_DSN=

# Email Configuration (Optional for queue workers)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Database User (for Docker)
MONGO_USER=admin
MONGO_PASSWORD=password

